@* Porta fiel de RegisterTenantPage.tsx *@
@page "/register"
@layout EmptyLayout
@inject TenantsService TenantsSvc
@inject NavigationManager Nav

<PageTitle>Criar conta — PDV + Estoque</PageTitle>

@if (Success)
{
    <div class="login-page">
        <div class="login-card" style="text-align:center">
            <h1 class="login-title" style="color:#1a7a4a">🎉 Conta criada!</h1>
            <p class="login-subtitle">
                Seu tenant foi cadastrado com sucesso. Você será redirecionado para o login em instantes…
            </p>
        </div>
    </div>
}
else
{
    <div class="login-page">
        <div class="login-card">
            <h1 class="login-title">Criar conta</h1>
            <p class="login-subtitle">Cadastre sua empresa e comece a usar o PDV + Estoque</p>

            <EditForm Model="@Model" OnValidSubmit="OnSubmit" class="login-form" novalidate>
                <DataAnnotationsValidator />

                <label class="login-label" for="register-name">Nome da empresa</label>
                <InputText id="register-name"
                           autocomplete="organization"
                           placeholder="Minha Loja LTDA"
                           class="login-input"
                           @bind-Value="Model.Name" />
                <ValidationMessage For="() => Model.Name" class="login-error" />

                <label class="login-label" for="register-email">E-mail do administrador</label>
                <InputText id="register-email"
                           type="email"
                           autocomplete="email"
                           placeholder="admin@minhaloja.com"
                           class="login-input"
                           @bind-Value="Model.AdminEmail" />
                <ValidationMessage For="() => Model.AdminEmail" class="login-error" />

                <label class="login-label" for="register-password">Senha</label>
                <div class="login-password-row">
                    <input id="register-password"
                           type="@(ShowPassword ? "text" : "password")"
                           autocomplete="new-password"
                           class="login-input"
                           @bind="Model.AdminPassword"
                           @bind:event="oninput" />
                    <button type="button"
                            class="login-toggle"
                            aria-pressed="@ShowPassword"
                            @onclick="() => ShowPassword = !ShowPassword">
                        @(ShowPassword ? "Ocultar" : "Mostrar")
                    </button>
                </div>
                <ValidationMessage For="() => Model.AdminPassword" class="login-error" />

                <label class="login-label" for="register-confirm">Confirmar senha</label>
                <input id="register-confirm"
                       type="@(ShowPassword ? "text" : "password")"
                       autocomplete="new-password"
                       class="login-input"
                       @bind="ConfirmPassword"
                       @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(ConfirmError))
                {
                    <p class="login-error" role="alert">@ConfirmError</p>
                }

                @if (!string.IsNullOrEmpty(SubmitError))
                {
                    <p class="login-error" role="alert">@SubmitError</p>
                }

                <button type="submit" id="register-submit" class="login-submit" disabled="@Submitting">
                    @(Submitting ? "Criando conta…" : "Criar conta")
                </button>
            </EditForm>

            <p class="login-hint">Já tem uma conta? <a href="/login">Entrar</a></p>
        </div>
    </div>
}

@code {
    private RegisterModel Model { get; set; } = new();
    private string ConfirmPassword { get; set; } = "";
    private bool ShowPassword { get; set; }
    private bool Submitting { get; set; }
    private bool Success { get; set; }
    private string? SubmitError { get; set; }
    private string? ConfirmError { get; set; }

    private async Task OnSubmit()
    {
        ConfirmError = null;
        SubmitError  = null;

        if (ConfirmPassword != Model.AdminPassword)
        {
            ConfirmError = "As senhas não coincidem.";
            return;
        }

        Submitting = true;
        try
        {
            await TenantsSvc.RegisterTenantAsync(new RegisterTenantPayload
            {
                Name          = Model.Name.Trim(),
                AdminEmail    = Model.AdminEmail.Trim(),
                AdminPassword = Model.AdminPassword,
            });
            Success = true;
            await Task.Delay(2500);
            Nav.NavigateTo("/login", replace: true);
        }
        catch (HttpRequestException ex)
        {
            SubmitError = ex.Message.Length > 0 ? ex.Message : "Não foi possível criar o tenant.";
        }
        catch (Exception ex)
        {
            SubmitError = ex.Message.Length > 0 ? ex.Message : "Erro inesperado.";
        }
        finally
        {
            Submitting = false;
        }
    }

    private class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "O nome da empresa é obrigatório.")]
        [System.ComponentModel.DataAnnotations.MaxLength(100, ErrorMessage = "Máximo de 100 caracteres.")]
        public string Name { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "O e-mail é obrigatório.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Informe um e-mail válido.")]
        public string AdminEmail { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "A senha é obrigatória.")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "A senha deve ter no mínimo 6 caracteres.")]
        public string AdminPassword { get; set; } = "";
    }
}
