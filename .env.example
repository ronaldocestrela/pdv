# Copie para `.env` e ajuste os valores (não commite `.env`).
# Política do SQL Server: senha forte (maiúscula, minúscula, número e símbolo).

SQL_DATABASE=PdvDb
SQL_PORT=1433
API_PORT=5190
WEB_PORT=8080

# Origem do frontend no navegador (precisa bater com http://localhost:<WEB_PORT>)
CORS_ORIGIN=http://localhost:8080

# URL da API no navegador (build do Vite; use host + API_PORT)
VITE_API_URL=http://localhost:5190

MSSQL_SA_PASSWORD=ChangeMe_StrongP@ssw0rd

# Mínimo recomendado: chave longa (ex.: >= 32 caracteres) para HS256
JWT_KEY=DevelopmentOnly_ChangeInProduction_Use_LongSymmetricKey_Min32Chars!!

JWT_ISSUER=pdv-local
JWT_AUDIENCE=pdv-web

SEED_SUPERADMIN_EMAIL=admin@local
SEED_SUPERADMIN_PASSWORD=ChangeMe123!
